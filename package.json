{
  "name": "pmaios",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:full": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:api\"",
    "dev:backend": "tsx watch src/backend/server.ts",
    "dev:frontend": "vite",
    "dev:api": "tsx watch src/server/index.ts",
    "start": "node dist/backend/src/backend/server.js",
    "start:backend": "tsx src/backend/server.ts",
    "start:legacy-api": "tsx src/server/index.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "tsc -p tsconfig.backend.json",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.backend.json",
    "audit:frontend-style": "node scripts/audit-frontend-workbench-style.mjs",
    "ui:schema:check": "node --experimental-strip-types scripts/check-ui-demo-patterns.ts --schema-only",
    "ui:lint": "node --experimental-strip-types scripts/check-ui-demo-patterns.ts",
    "validate": "npm run lint && npm run ui:schema:check && npm run ui:lint",
    "verify:frontend-browser": "node scripts/run-playwright-frontend-verification.mjs",
    "verify:frontend-delivery": "node scripts/run-frontend-delivery-regression.mjs",
    "cli": "tsx src/cli/aios.ts",
    "dingtalk:ui": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dingtalk-ui-automation.ps1"
  },
  "dependencies": {
    "@ant-design/charts": "^2.6.7",
    "@ant-design/colors": "^8.0.1",
    "@ant-design/icons": "^6.2.2",
    "@ant-design/x": "^2.7.0",
    "@ant-design/x-card": "^2.7.0",
    "@ant-design/x-markdown": "^2.7.0",
    "@ant-design/x-sdk": "^2.7.0",
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.8",
    "@notionhq/client": "^5.17.0",
    "@xenova/transformers": "^2.17.2",
    "antd": "^6.3.7",
    "antd-mini": "^3.4.3",
    "antd-mobile": "^5.42.3",
    "antd-style": "^4.1.0",
    "chromadb": "^3.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "langchain": "^1.3.1",
    "mammoth": "^1.12.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}
